                </div>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="liveToast" class="toast custom-toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas" :class="toastIcon" :class="toastClass"></i>
                <strong class="ms-2 me-auto">{{ toastTitle }}</strong>
                <small>{{ toastTime }}</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">{{ toastMessage }}</div>
        </div>
    </div>

    <!-- Help Modal -->
    <div class="modal fade" id="helpModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Server Monitoring Setup Guide</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Follow these steps to enable monitoring on your web servers
                    </div>
                    
                    <h6 class="fw-bold text-primary mt-4">
                        <i class="fab fa-apache me-2"></i>Apache Configuration (mod_status)
                    </h6>
                    <p>Enable Apache's built-in status module:</p>
                    <pre class="code-block"># Enable the status module
sudo a2enmod status

# Create status configuration
sudo nano /etc/apache2/conf-available/status.conf</pre>
                    
                    <p>Add the following configuration:</p>
                    <pre class="code-block">&lt;Location /server-status&gt;
    SetHandler server-status
    Require local
    # For remote access, use:
    # Require ip 192.168.1.0/24
&lt;/Location&gt;

ExtendedStatus On</pre>
                    
                    <p>Enable and restart Apache:</p>
                    <pre class="code-block">sudo a2enconf status
sudo systemctl reload apache2

# Test the status page
curl http://localhost/server-status?auto</pre>
                    
                    <hr class="my-4">
                    
                    <h6 class="fw-bold text-success">
                        <i class="fas fa-server me-2"></i>Nginx Configuration (stub_status)
                    </h6>
                    <p>Create Nginx status configuration:</p>
                    <pre class="code-block">sudo nano /etc/nginx/sites-available/status</pre>
                    
                    <p>Add the following configuration:</p>
                    <pre class="code-block">server {
    listen 127.0.0.1:8080;
    server_name localhost;
    
    location /nginx_status {
        stub_status on;
        access_log off;
        allow 127.0.0.1;
        deny all;
    }
}</pre>
                    
                    <p>Enable and test the configuration:</p>
                    <pre class="code-block"># Enable the site
sudo ln -s /etc/nginx/sites-available/status /etc/nginx/sites-enabled/

# Test configuration
sudo nginx -t

# Reload Nginx
sudo systemctl reload nginx

# Test the status page
curl http://127.0.0.1:8080/nginx_status</pre>
                    
                    <div class="alert alert-warning mt-4">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Security Note:</strong> Always restrict access to status pages to trusted IP addresses only.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Save Documentation</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div class="modal fade" id="confirmModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ confirmTitle }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        {{ confirmMessage }}
                    </div>
                    <p class="text-muted small mb-0">{{ confirmDetails }}</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" @click="executeConfirmedAction" data-bs-dismiss="modal">Confirm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const { createApp } = Vue;
    const socket = io();
    let chartInstance = null;

    createApp({
        data() {
            return {
                agents: {},
                selectedAgentId: null,
                lastUpdate: new Date(),
                dashboardLatency: 0,
                sidebarActive: false,
                // Toast data
                toastTitle: '',
                toastMessage: '',
                toastClass: '',
                toastIcon: '',
                toastTime: '',
                // Confirmation modal data
                confirmTitle: '',
                confirmMessage: '',
                confirmDetails: '',
                pendingAction: null,
                pendingPayload: null
            }
        },
        computed: {
            currentAgent() {
                return this.selectedAgentId ? this.agents[this.selectedAgentId] : null;
            },
            lastUpdateStr() {
                const now = new Date();
                const diff = now - this.lastUpdate;
                if (diff < 60000) return 'Just now';
                if (diff < 3600000) return `${Math.floor(diff / 60000)} min ago`;
                return this.lastUpdate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            }
        },
        watch: {
            selectedAgentId(val) {
                if (val) {
                    this.$nextTick(() => this.initChart());
                    if (window.innerWidth < 992) {
                        this.sidebarActive = false;
                    }
                }
            }
        },
        methods: {
            selectAgent(id) {
                this.selectedAgentId = id;
            },
            toggleSidebar() {
                this.sidebarActive = !this.sidebarActive;
            },
            formatBytes(bytes) {
                if (!bytes || bytes === 0) return '0 B';
                const k = 1024;
                const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            },
            formatUptime(seconds) {
                if (!seconds) return '-';
                const days = Math.floor(seconds / 86400);
                const hours = Math.floor((seconds % 86400) / 3600);
                const minutes = Math.floor((seconds % 3600) / 60);
                
                if (days > 0) return `${days}d ${hours}h`;
                if (hours > 0) return `${hours}h ${minutes}m`;
                return `${minutes}m`;
            },
            getActiveServices() {
                let count = 0;
                if (this.currentAgent?.metrics.mysql?.status === 'Online') count++;
                if (this.currentAgent?.metrics.nginx?.status === 'Active') count++;
                if (this.currentAgent?.metrics.apache?.ServerVersion) count++;
                if (this.currentAgent?.metrics.redis?.status === 'Up') count++;
                return count;
            },
            // Confirmation methods
            confirmAction(action, payload = null) {
                this.pendingAction = action;
                this.pendingPayload = payload;
                
                const actions = {
                    'reboot-os': {
                        title: 'Reboot Server',
                        message: 'Are you sure you want to reboot this server?',
                        details: 'All services will be restarted. This action may cause downtime.'
                    },
                    'delete-redis-key': {
                        title: 'Delete Redis Key',
                        message: `Delete key "${payload}"?`,
                        details: 'This action cannot be undone.'
                    },
                    'kill-process': {
                        title: 'Kill Process',
                        message: `Kill process ID ${payload}?`,
                        details: 'This may cause the application to stop working.'
                    },
                    'pm2-restart': {
                        title: 'Restart PM2 Process',
                        message: `Restart PM2 process ID ${payload}?`,
                        details: 'The application will be temporarily unavailable.'
                    }
                };
                
                const config = actions[action] || {
                    title: 'Confirm Action',
                    message: 'Are you sure?',
                    details: ''
                };
                
                this.confirmTitle = config.title;
                this.confirmMessage = config.message;
                this.confirmDetails = config.details;
                
                const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
                modal.show();
            },
            executeConfirmedAction() {
                if (!this.pendingAction) return;
                
                const payload = this.pendingAction === 'delete-redis-key' || 
                              this.pendingAction === 'kill-process' || 
                              this.pendingAction === 'pm2-restart' ? 
                              this.pendingPayload : {};
                
                socket.emit('send-command', {
                    agentId: this.selectedAgentId,
                    command: this.pendingAction,
                    payload: payload
                });
                
                this.pendingAction = null;
                this.pendingPayload = null;
            },
            confirmDeleteKey(key) {
                this.confirmAction('delete-redis-key', key);
            },
            confirmKillProcess(pid) {
                this.confirmAction('kill-process', pid);
            },
            confirmRestartPM2(pmId) {
                this.confirmAction('pm2-restart', pmId);
            },
            showToast(title, message, type = 'success') {
                this.toastTitle = title;
                this.toastMessage = message;
                this.toastTime = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                
                const configs = {
                    success: { class: 'bg-success', icon: 'fa-check-circle' },
                    error: { class: 'bg-danger', icon: 'fa-exclamation-circle' },
                    info: { class: 'bg-info', icon: 'fa-info-circle' },
                    warning: { class: 'bg-warning', icon: 'fa-exclamation-triangle' }
                };
                
                const config = configs[type] || configs.info;
                this.toastClass = config.class;
                this.toastIcon = config.icon;
                
                const toastEl = document.getElementById('liveToast');
                const toast = new bootstrap.Toast(toastEl);
                toast.show();
            },
            initChart() {
                if (chartInstance) {
                    chartInstance.destroy();
                    chartInstance = null;
                }
                
                const ctx = document.getElementById('netChart');
                if (!ctx) return;
                
                const gradientTx = ctx.getContext('2d').createLinearGradient(0, 0, 0, 250);
                gradientTx.addColorStop(0, 'rgba(59, 130, 246, 0.3)');
                gradientTx.addColorStop(1, 'rgba(59, 130, 246, 0)');
                
                const gradientRx = ctx.getContext('2d').createLinearGradient(0, 0, 0, 250);
                gradientRx.addColorStop(0, 'rgba(16, 185, 129, 0.3)');
                gradientRx.addColorStop(1, 'rgba(16, 185, 129, 0)');
                
                chartInstance = new Chart(ctx.getContext('2d'), {
                    type: 'line',
                    data: {
                        labels: Array(20).fill(''),
                        datasets: [
                            {
                                label: 'TX',
                                borderColor: '#3b82f6',
                                backgroundColor: gradientTx,
                                data: Array(20).fill(0),
                                tension: 0.4,
                                pointRadius: 0,
                                borderWidth: 2,
                                fill: true
                            },
                            {
                                label: 'RX',
                                borderColor: '#10b981',
                                backgroundColor: gradientRx,
                                data: Array(20).fill(0),
                                tension: 0.4,
                                pointRadius: 0,
                                borderWidth: 2,
                                fill: true
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                                titleFont: { size: 12 },
                                bodyFont: { size: 12 },
                                padding: 10,
                                displayColors: false,
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) label += ': ';
                                        label += context.parsed.y.toFixed(2) + ' MB/s';
                                        return label;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { display: false },
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0, 0, 0, 0.05)' },
                                ticks: {
                                    callback: function(value) {
                                        return value + ' MB/s';
                                    }
                                }
                            }
                        },
                        interaction: { intersect: false, mode: 'index' }
                    }
                });
            },
            updateChart(rx, tx) {
                if (!chartInstance) return;
                
                // Convert bytes to megabytes
                const rxMB = rx / (1024 * 1024);
                const txMB = tx / (1024 * 1024);
                
                chartInstance.data.datasets[0].data.shift();
                chartInstance.data.datasets[0].data.push(txMB);
                chartInstance.data.datasets[1].data.shift();
                chartInstance.data.datasets[1].data.push(rxMB);
                
                chartInstance.update('none');
            },
            handleResize() {
                if (window.innerWidth >= 992) {
                    this.sidebarActive = true;
                } else {
                    this.sidebarActive = false;
                }
            }
        },
        mounted() {
            // Initialize WebSocket listeners
            socket.on('ui-init-state', data => {
                this.agents = data;
                if (!this.selectedAgentId && Object.keys(data).length) {
                    this.selectedAgentId = Object.keys(data)[0];
                }
            });
            
            socket.on('ui-new-agent', ({ id, data }) => {
                this.agents[id] = data;
                if (!this.selectedAgentId) this.selectedAgentId = id;
                this.showToast('New Server Connected', `${data.info.name} has joined the cluster`, 'success');
            });
            
            socket.on('ui-update-metrics', ({ agentId, data }) => {
                if (!this.agents[agentId]) {
                    this.agents[agentId] = {
                        info: { id: agentId, name: agentId, status: 'online' },
                        metrics: data
                    };
                }
                
                this.agents[agentId].metrics = data;
                this.agents[agentId].info.status = 'online';
                this.lastUpdate = new Date();
                
                // Calculate latency
                if (data.sent_at) {
                    this.dashboardLatency = Date.now() - data.sent_at;
                }
                
                // Update chart if this is the selected agent
                if (this.selectedAgentId === agentId) {
                    this.updateChart(data.network?.rx || 0, data.network?.tx || 0);
                }
            });
            
            socket.on('agent-status-change', ({ id, status }) => {
                if (this.agents[id]) {
                    this.agents[id].info.status = status;
                    const agentName = this.agents[id].info.name;
                    this.showToast(
                        `Server ${status === 'offline' ? 'Disconnected' : 'Reconnected'}`,
                        `${agentName} is now ${status}`,
                        status === 'offline' ? 'error' : 'success'
                    );
                }
            });
            
            socket.on('ui-command-notification', (response) => {
                this.showToast(
                    response.success ? 'Command Executed' : 'Command Failed',
                    response.msg,
                    response.success ? 'success' : 'error'
                );
            });
            
            // Initialize chart
            this.$nextTick(() => {
                if (this.selectedAgentId) {
                    this.initChart();
                }
            });
            
            // Handle window resize
            window.addEventListener('resize', this.handleResize);
            this.handleResize(); // Initial call
            
            // Auto-refresh indicator
            setInterval(() => {
                this.lastUpdate = new Date();
            }, 30000);
        },
        beforeUnmount() {
            window.removeEventListener('resize', this.handleResize);
        }
    }).mount('#app');
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>