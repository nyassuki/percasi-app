            <div class="col-lg-4 grid-item">
                <div class="table-container h-100">
                    <div class="table-header">
                        <div class="table-title">
                            <i class="fas fa-database text-danger"></i>
                            Redis Monitor
                        </div>
                        <span class="badge" :class="currentAgent.metrics.redis?.status==='Up'?'badge-online':'badge-offline'">
                            {{ currentAgent.metrics.redis?.status || 'Down' }}
                        </span>
                    </div>
                    <div class="table-responsive" style="max-height: 300px;" v-if="currentAgent.metrics.redis?.status==='Up'">
                        <table class="table custom-table">
                            <thead>
                                <tr>
                                    <th>Key</th>
                                    <th>Type</th>
                                    <th>TTL</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="k in currentAgent.metrics.redis.key_list || []" :key="k.name">
                                    <td class="text-truncate" style="max-width: 100px;">{{ k.name }}</td>
                                    <td><span class="badge bg-secondary">{{ k.type }}</span></td>
