                            <i class="fas fa-tasks text-primary"></i>
                            Top Processes
                        </div>
                        <small class="text-muted">CPU Intensive</small>
                    </div>
                    <div class="table-responsive" style="max-height: 300px;">
                        <table class="table custom-table">
                            <thead>
                                <tr>
                                    <th>Process</th>
