                                    <th>CPU</th>
                                    <th>Memory</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="p in currentAgent.metrics.top_procs || []" :key="p.pid">
                                    <td class="text-truncate" style="max-width: 120px;">{{ p.name }}</td>
                                    <td>{{ p.user }}</td>
                                    <td class="fw-bold" :class="p.cpu > 50 ? 'text-danger' : ''">{{ p.cpu }}%</td>
                                    <td>{{ p.mem }}%</td>
                                    <td class="text-end">
                                        <button class="action-btn" @click="confirmKillProcess(p.pid)" title="Kill Process">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                                <tr v-if="!currentAgent.metrics.top_procs?.length">
                                    <td colspan="5" class="text-center text-muted py-3">No process data</td>
                                </tr>
                            </tbody>
                        </table>
