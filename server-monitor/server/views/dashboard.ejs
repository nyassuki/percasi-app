<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cluster Monitor Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>

    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3a0ca3;
            --success-color: #06d6a0;
            --warning-color: #ffd166;
            --danger-color: #ef476f;
            --dark-color: #1a1a2e;
            --light-color: #f8f9fa;
            --gray-color: #6c757d;
            --sidebar-width: 280px;
            --transition-speed: 0.3s;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e4edf5 100%);
            color: #333;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, var(--dark-color) 0%, #16213e 100%);
            color: var(--light-color);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
            transition: all var(--transition-speed) ease;
        }

        .sidebar-header {
            padding: 1.5rem 1.5rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .sidebar-header .logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
        }

        .logo-icon {
            background: var(--primary-color);
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .agent-list {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 0;
        }

        .agent-item {
            padding: 1rem 1.5rem;
            margin: 0.3rem 0.8rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            border-left: 4px solid transparent;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .agent-item:hover {
            background: rgba(255, 255, 255, 0.08);
            transform: translateX(5px);
        }

        .agent-item.active {
            background: rgba(67, 97, 238, 0.15);
            border-left-color: var(--primary-color);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.2);
        }

        .agent-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.3rem;
        }

        .agent-name {
            font-weight: 600;
            font-size: 0.95rem;
            color: white;
        }

        .agent-status {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            position: relative;
        }

        .agent-status.online {
            background: var(--success-color);
            box-shadow: 0 0 0 3px rgba(6, 214, 160, 0.2);
        }

        .agent-status.offline {
            background: var(--danger-color);
        }

        .agent-details {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        /* Main Content */
        .main {
            margin-left: var(--sidebar-width);
            padding: 1.5rem;
            min-height: 100vh;
            transition: all var(--transition-speed) ease;
        }

        @media (max-width: 992px) {
            .sidebar {
                transform: translateX(-100%);
            }
            
            .sidebar.active {
                transform: translateX(0);
            }
            
            .main {
                margin-left: 0;
            }
            
            .mobile-toggle {
                display: block !important;
            }
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding: 1.5rem;
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .header-title h1 {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--dark-color);
            margin-bottom: 0.2rem;
        }

        .header-title p {
            color: var(--gray-color);
            font-size: 0.9rem;
            margin-bottom: 0;
        }

        .header-stats {
            display: flex;
            gap: 1.5rem;
            align-items: center;
        }

        .stat-badge {
            background: white;
            border: 1px solid #e9ecef;
            padding: 0.5rem 1rem;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .stat-badge i {
            font-size: 1rem;
        }

        /* Cards */
        .metric-card {
            background: white;
            border: none;
            border-radius: 16px;
            padding: 1.5rem;
            height: 100%;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .metric-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: var(--primary-color);
            border-radius: 4px 0 0 4px;
        }

        .metric-card.cpu::before { background: var(--danger-color); }
        .metric-card.memory::before { background: var(--primary-color); }
        .metric-card.disk::before { background: var(--warning-color); }
        .metric-card.services::before { background: var(--success-color); }

        .metric-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }

        .metric-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: white;
        }

        .metric-icon.cpu { background: linear-gradient(135deg, var(--danger-color), #ff6b6b); }
        .metric-icon.memory { background: linear-gradient(135deg, var(--primary-color), #4cc9f0); }
        .metric-icon.disk { background: linear-gradient(135deg, var(--warning-color), #ff9e00); }
        .metric-icon.services { background: linear-gradient(135deg, var(--success-color), #4adf7f); }

        .metric-value {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--dark-color);
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .metric-label {
            font-size: 0.85rem;
            text-transform: uppercase;
            color: var(--gray-color);
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .metric-details {
            font-size: 0.8rem;
            color: var(--gray-color);
            margin-top: 0.5rem;
        }

        /* Progress Bars */
        .progress-container {
            margin-top: 1rem;
        }

        .progress-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            margin-bottom: 0.3rem;
            color: var(--gray-color);
        }

        .progress {
            height: 8px;
            border-radius: 10px;
            background: #e9ecef;
            overflow: hidden;
        }

        .progress-bar {
            border-radius: 10px;
            transition: width 0.6s ease;
        }

        /* Charts */
        .chart-container {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            height: 100%;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .chart-title {
            font-weight: 600;
            color: var(--dark-color);
            font-size: 1.1rem;
        }

        .chart-stats {
            display: flex;
            gap: 1rem;
            font-size: 0.9rem;
        }

        .chart-stat {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .chart-stat i {
            font-size: 0.8rem;
        }

        /* Tables */
        .table-container {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .table-header {
            padding: 1.2rem 1.5rem;
            background: white;
            border-bottom: 1px solid #e9ecef;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .table-title {
            font-weight: 600;
            color: var(--dark-color);
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .custom-table {
            margin-bottom: 0;
        }

        .custom-table thead th {
            background: #f8f9fa;
            border-bottom: 2px solid #e9ecef;
            font-weight: 600;
            color: var(--gray-color);
            padding: 1rem 1.5rem;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .custom-table tbody td {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #e9ecef;
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .custom-table tbody tr:hover {
            background: #f8f9fa;
        }

        /* Badges */
        .badge {
            font-weight: 500;
            padding: 0.4em 0.8em;
            border-radius: 8px;
            font-size: 0.75rem;
        }

        .badge-online {
            background: rgba(6, 214, 160, 0.1);
            color: var(--success-color);
        }

        .badge-offline {
            background: rgba(239, 71, 111, 0.1);
            color: var(--danger-color);
        }

        .badge-warning {
            background: rgba(255, 209, 102, 0.1);
            color: #e6a100;
        }

        /* Buttons */
        .btn {
            border-radius: 10px;
            font-weight: 500;
            padding: 0.5rem 1.2rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color), #3a0ca3);
            border: none;
        }

        .btn-danger {
            background: linear-gradient(135deg, var(--danger-color), #d90429);
            border: none;
        }

        .btn-sm {
            padding: 0.35rem 0.8rem;
            font-size: 0.85rem;
        }

        .action-btn {
            width: 30px;
            height: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            border: 1px solid #e9ecef;
            background: white;
            color: var(--gray-color);
            transition: all 0.2s ease;
        }

        .action-btn:hover {
            background: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
        }

        /* Toast */
        .toast-container {
            z-index: 9999;
        }

        .custom-toast {
            border-radius: 12px;
            border: none;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.15);
        }

        /* Modal */
        .modal-content {
            border-radius: 16px;
            border: none;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        }

        .modal-header {
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            border-bottom: 1px solid #dee2e6;
            border-radius: 16px 16px 0 0;
            padding: 1.5rem;
        }

        .modal-body {
            padding: 1.5rem;
        }

        .code-block {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 1.2rem;
            border-radius: 10px;
            font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
            font-size: 0.85rem;
            border: 1px solid #333;
            overflow-x: auto;
            margin: 1rem 0;
        }

        /* Responsive */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 1rem;
            left: 1rem;
            z-index: 1001;
            background: white;
            border: none;
            width: 45px;
            height: 45px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: var(--dark-color);
        }

        /* Loading State */
        .loading-skeleton {
            background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
            border-radius: 8px;
        }

        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.5s ease forwards;
        }

        /* Empty State */
        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem;
            text-align: center;
            color: var(--gray-color);
        }

        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.3;
        }

        /* Grid Layout */
        .grid-item {
            margin-bottom: 1.5rem;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #a1a1a1;
        }
    </style>
</head>
<body>
<div id="app">
    <!-- Mobile Toggle Button -->
    <button class="mobile-toggle" @click="toggleSidebar">
        <i class="fas fa-bars"></i>
    </button>

    <!-- Sidebar -->
    <div class="sidebar" :class="{active: sidebarActive}">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-server"></i>
                </div>
                <span>ClusterMon</span>
            </div>
            <small class="text-muted mt-2 d-block">Real-time Monitoring Dashboard</small>
        </div>

        <div class="agent-list">
            <div v-for="(agent, id) in agents" :key="id" 
                 @click="selectAgent(id)" 
                 class="agent-item fade-in" 
                 :class="{active: selectedAgentId===id}">
                <div class="agent-info">
                    <span class="agent-name">{{ agent.info.name }}</span>
                    <div class="agent-status" :class="agent.info.status"></div>
                </div>
                <div class="agent-details">
                    <i class="fas fa-desktop"></i>
                    <span>{{ agent.metrics.os?.hostname || 'Unknown' }}</span>
                </div>
                <div class="agent-details mt-1">
                    <i class="fas fa-microchip"></i>
                    <span>{{ agent.metrics.cpu?.cores || 0 }} Cores</span>
                    <i class="fas fa-memory ms-2"></i>
                    <span>{{ formatBytes(agent.metrics.memory?.total) }}</span>
                </div>
            </div>
            
            <div v-if="Object.keys(agents).length === 0" class="empty-state">
                <i class="fas fa-server"></i>
                <p>No servers connected</p>
            </div>
        </div>

        <div class="sidebar-footer">
            <button class="btn btn-outline-light w-100" data-bs-toggle="modal" data-bs-target="#helpModal">
                <i class="fas fa-question-circle me-2"></i>Setup Guide
            </button>
            <a href="/logout" class="btn btn-outline-light w-100">
                <i class="fas fa-sign-out-alt me-2"></i>Logout
            </a>
            <small class="text-center text-muted mt-2">v2.1.0 • © 2024</small>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main">
        <!-- Dashboard Header -->
        <div class="dashboard-header" v-if="currentAgent">
            <div class="header-title">
                <h1>{{ currentAgent.info.name }}</h1>
                <p>
                    <i class="fab fa-linux me-1"></i> {{ currentAgent.metrics.os?.distro || 'Unknown' }} • 
                    <i class="fas fa-clock me-1"></i> Uptime: {{ formatUptime(currentAgent.metrics.os?.uptime) }}
                </p>
            </div>
            <div class="header-stats">
                <div class="stat-badge">
                    <i class="fas fa-globe text-primary"></i>
                    <div>
                        <div class="small text-muted">Network Ping</div>
                        <strong :class="currentAgent.metrics.network?.ping > 100 ? 'text-danger' : 'text-success'">
                            {{ currentAgent.metrics.network?.ping || 0 }}ms
                        </strong>
                    </div>
                </div>
                <div class="stat-badge">
                    <i class="fas fa-tachometer-alt text-warning"></i>
                    <div>
                        <div class="small text-muted">Dashboard Lag</div>
                        <strong>{{ dashboardLatency }}ms</strong>
                    </div>
                </div>
                <div class="stat-badge">
                    <i class="fas fa-sync-alt text-info"></i>
                    <div>
                        <div class="small text-muted">Last Update</div>
                        <strong>{{ lastUpdateStr }}</strong>
                    </div>
                </div>
                <button class="btn btn-danger" @click="confirmAction('reboot-os')">
                    <i class="fas fa-power-off me-1"></i>Reboot Server
                </button>
            </div>
        </div>

        <!-- Empty State -->
        <div v-if="!currentAgent" class="empty-state mt-5">
            <i class="fas fa-server fa-4x mb-4"></i>
            <h3 class="mb-3">No Server Selected</h3>
            <p class="text-muted mb-4">Select a server from the sidebar to view monitoring data</p>
            <button class="btn btn-primary" @click="toggleSidebar">
                <i class="fas fa-bars me-2"></i>Browse Servers
            </button>
        </div>

        <!-- Metrics Grid -->
        <div v-if="currentAgent" class="row g-4">
            <!-- CPU Card -->
            <div class="col-xl-3 col-lg-6 grid-item">
                <div class="metric-card cpu">
                    <div class="metric-header">
                        <div>
                            <div class="metric-label">CPU Load</div>
                            <div class="metric-value">{{ currentAgent.metrics.cpu?.load || 0 }}%</div>
                        </div>
                        <div class="metric-icon cpu">
                            <i class="fas fa-microchip"></i>
                        </div>
                    </div>
                    <div class="progress-container">
                        <div class="progress-label">
                            <span>Utilization</span>
                            <span>{{ currentAgent.metrics.cpu?.load || 0 }}%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-danger" :style="{width: currentAgent.metrics.cpu?.load + '%'}"></div>
                        </div>
                    </div>
                    <div class="metric-details">
                        {{ currentAgent.metrics.cpu?.cores || 0 }} Cores • {{ currentAgent.metrics.cpu?.model || 'Unknown' }}
                    </div>
                </div>
            </div>

            <!-- Memory Card -->
            <div class="col-xl-3 col-lg-6 grid-item">
                <div class="metric-card memory">
                    <div class="metric-header">
                        <div>
                            <div class="metric-label">Memory</div>
                            <div class="metric-value">{{ currentAgent.metrics.memory?.percent || 0 }}%</div>
                        </div>
                        <div class="metric-icon memory">
                            <i class="fas fa-memory"></i>
                        </div>
                    </div>
                    <div class="progress-container">
                        <div class="progress-label">
                            <span>Used: {{ formatBytes(currentAgent.metrics.memory?.used) }}</span>
                            <span>Total: {{ formatBytes(currentAgent.metrics.memory?.total) }}</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-primary" :style="{width: currentAgent.metrics.memory?.percent + '%'}"></div>
                        </div>
                    </div>
                    <div class="metric-details">
                        Free: {{ formatBytes(currentAgent.metrics.memory?.free) }}
                    </div>
                </div>
            </div>

            <!-- Disk Card -->
            <div class="col-xl-3 col-lg-6 grid-item">
                <div class="metric-card disk">
                    <div class="metric-header">
                        <div>
                            <div class="metric-label">Storage</div>
                            <div class="metric-value">{{ currentAgent.metrics.disk?.percent || 0 }}%</div>
                        </div>
                        <div class="metric-icon disk">
                            <i class="fas fa-hdd"></i>
                        </div>
                    </div>
                    <div class="progress-container">
                        <div class="progress-label">
                            <span>Root Partition</span>
                            <span>{{ currentAgent.metrics.disk?.percent || 0 }}%</span>
                        </div>
                        <div class="progress">
                            <div class="progress-bar bg-warning" :style="{width: (currentAgent.metrics.disk?.percent || 0) + '%'}"></div>
                        </div>
                    </div>
                    <div class="metric-details">
                        Used: {{ formatBytes(currentAgent.metrics.disk?.used) }}
                    </div>
                </div>
            </div>

            <!-- Services Card -->
            <div class="col-xl-3 col-lg-6 grid-item">
                <div class="metric-card services">
                    <div class="metric-header">
                        <div>
                            <div class="metric-label">Services</div>
                            <div class="metric-value">{{ getActiveServices() }}</div>
                        </div>
                        <div class="metric-icon services">
                            <i class="fas fa-cogs"></i>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small>Web Connections</small>
                            <strong class="text-success">{{ currentAgent.metrics.web_conn || 0 }}</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small>MySQL</small>
                            <span class="badge" :class="currentAgent.metrics.mysql?.status==='Online'?'badge-online':'badge-offline'">
                                {{ currentAgent.metrics.mysql?.status || 'Offline' }}
                            </span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <small>Web Server</small>
                            <span class="badge badge-warning">
                                {{ currentAgent.metrics.nginx?.status==='Active' ? 'Nginx' : (currentAgent.metrics.apache?.status==='Active' ? 'Apache' : 'None') }}
                            </span>
                        </div>
                    </div>
                </div>
